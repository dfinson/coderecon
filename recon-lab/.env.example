# Recon Lab — Environment Variables
#
# Copy to .env and fill in values. The CLI reads these automatically.
#
# LLM provider — pick ONE section.

# ── Option A: Azure AI Foundry (provisioned via infra/) ──────────
# After `cd ../infra && terraform apply`:
#   terraform output -raw ai_services_endpoint
AZURE_OPENAI_ENDPOINT=https://coderecon-lab-ai.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Auth: uses DefaultAzureCredential (az login). No API key needed.

# ── Option B: GitHub Models (default, no infra required) ─────────
# Uses `gh auth token` automatically. Or set explicitly:
# GITHUB_TOKEN=ghp_...

# ── LLM model selection (set in lab.toml [swebench] section) ─────
# lab.toml llm_model = "openai/gpt-4.1-mini"   ← GitHub Models
# lab.toml llm_model = "azure/gpt-4.1-mini"     ← Azure Foundry
